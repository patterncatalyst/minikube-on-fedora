# order-service Containerfile — UBI 9 multi-stage build (CAP-005).
# r23: also copies committed gRPC client stubs (gen/) — CAP-013.
#
# r21b fix: the UBI 9 python-312 image's default user is 1001, which cannot
# write to /opt/venv (/opt is root-owned). The r21/r21a build failed with
# "Permission denied: '/opt/venv'".
#
# Fix (idiomatic multi-stage): the BUILDER stage runs as root — it's
# discarded, so there's no security cost to writing /opt/venv there. Only the
# RUNTIME stage enforces the non-root user (1001:0), and it merely reads and
# executes the copied venv (with --chown to make ownership unambiguous).
#
# Per CONTRIBUTING.md: UBI 9 base, runtime as USER 1001:0, no
# subscription-manager needed.

# ─── Builder (runs as root; image discarded) ─────────────────────────────────
FROM registry.access.redhat.com/ubi9/python-312:latest AS builder

USER 0
WORKDIR /build

# Install Poetry + export plugin. Pin both for reproducibility.
RUN pip install --no-cache-dir "poetry==1.8.4" "poetry-plugin-export==1.8.0"

# Dependency manifests first for layer caching. poetry.lock* glob works
# whether or not the lock is committed (committing recommended — CAP-001).
COPY pyproject.toml poetry.lock* ./

# Export pinned requirements and install into an isolated venv at /opt/venv.
# Root can write /opt here; the runtime stage only reads the result.
RUN poetry export --without-hashes --only main -f requirements.txt -o requirements.txt \
    && python -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# ─── Runtime (non-root) ──────────────────────────────────────────────────────
FROM registry.access.redhat.com/ubi9/python-312:latest AS runtime

WORKDIR /opt/app-root/src

# Copy the prebuilt venv, chowned to the runtime user so ownership is
# unambiguous. Then the application code.
COPY --from=builder --chown=1001:0 /opt/venv /opt/venv
COPY --chown=1001:0 app/ ./app/
# Committed gRPC stubs (capstone.inventory.v1). app/ adds this to sys.path.
COPY --chown=1001:0 gen/ ./gen/
# Canonical Avro schema this service owns and registers (r25b). app/events.py
# loads it from ../schemas/order-placed.avsc relative to the app package.
COPY --chown=1001:0 schemas/ ./schemas/

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Run as the UBI default non-root user (1001), group 0 (OpenShift restricted
# SCC compatible). CONTRIBUTING.md convention.
USER 1001:0

EXPOSE 8080

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
