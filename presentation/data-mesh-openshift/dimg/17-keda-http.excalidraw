      "updated": 1,
      "link": null,
      "locked": false,
      "type": "text",
      "x": 110,
      "y": 342.8,
      "width": 867,
      "height": 14,
      "strokeColor": "#3a3a3a",
      "backgroundColor": "transparent",
      "text": "order-service carries the canary; HTTP-scaling a service whose traffic is split by weight would have the two mechanisms fight over the same pods.",
      "originalText": "order-service carries the canary; HTTP-scaling a service whose traffic is split by weight would have the two mechanisms fight over the same pods.",
      "fontSize": 11.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25,
